{% extends "base.html.j2" %}

{% block title %}{{ site.section_title }} — {{ site.logo }}{% endblock %}

{% block extra_css %}
  .projects-page { padding: 3rem 0; }

  .projects-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin: 0 0 0.4rem;
  }

  .page-subtitle {
    color: var(--muted);
    font-size: 1rem;
    margin: 0;
  }
{% endblock %}

{% block content %}
  <section class="projects-page">
    <div class="section-inner">

      <div class="projects-header">
        <h1 class="page-title">{{ site.section_title }}</h1>
        {% if site.section_subtitle %}
        <p class="page-subtitle">{{ site.section_subtitle }}</p>
        {% endif %}
      </div>

      <div class="cards-grid">
        {% for card in projects %}
          {% include "_card.html.j2" %}
        {% endfor %}
      </div>

    </div>
  </section>
{% endblock %}
